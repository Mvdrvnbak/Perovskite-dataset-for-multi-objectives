def make_onehot(handle_unknown='ignore'):
    """
    Create OneHotEncoder safely across sklearn versions.
    Sets sparse_output=False or sparse=False if supported; otherwise creates encoder without those kwargs.
    """
    kwargs = {'handle_unknown': handle_unknown}
    sig = inspect.signature(OneHotEncoder.__init__)
    params = sig.parameters
    if 'sparse_output' in params:
        kwargs['sparse_output'] = False
    elif 'sparse' in params:
        kwargs['sparse'] = False
    # else: do not pass sparsity kwarg
    return OneHotEncoder(**kwargs)

def get_onehot_feature_names(ohe, input_columns):
    """Return feature names robustly across sklearn versions."""
    if hasattr(ohe, "get_feature_names_out"):
        return list(ohe.get_feature_names_out(input_columns))
    elif hasattr(ohe, "get_feature_names"):
        try:
            return list(ohe.get_feature_names(input_columns))
        except:
            # older signature might not accept input_columns
            return list(ohe.get_feature_names())
    else:
        # fallback: generate approximate names
        names = []
        for c in input_columns:
            names.append(c)
        return names

def make_tsne(**kwargs):
    """
    Create TSNE with argument name that fits installed sklearn.
    Accepts 'n_iter' in kwargs; will map to available parameter name (n_iter or max_iter).
    """
    sig = inspect.signature(TSNE.__init__)
    params = sig.parameters
    # prefer n_iter => map to max_iter if needed
    if 'n_iter' in kwargs:
        nval = kwargs.pop('n_iter')
        if 'n_iter' in params:
            kwargs['n_iter'] = nval
        elif 'max_iter' in params:
            kwargs['max_iter'] = nval
    return TSNE(**kwargs)

