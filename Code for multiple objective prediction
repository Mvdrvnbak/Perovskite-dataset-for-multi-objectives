def norm(s): return re.sub(r'[^a-z0-9]', '', str(s).lower())
col_norm_map = {c: norm(c) for c in df.columns}

def find_best_col(name):
    n = norm(name)
    for c, ncol in col_norm_map.items():
        if n == ncol: return c
    for c, ncol in col_norm_map.items():
        if n in ncol or ncol in n: return c
    tokens = set(re.findall(r'[a-z0-9]+', name.lower()))
    best, best_score = None, 0
    for c in df.columns:
        tokens2 = set(re.findall(r'[a-z0-9]+', c.lower()))
        score = len(tokens & tokens2)
        if score > best_score: best, best_score = c, score
    return best if best_score > 0 else None

