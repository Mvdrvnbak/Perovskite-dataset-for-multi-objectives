def make_onehot(handle_unknown="ignore"):
    kwargs = {"handle_unknown": handle_unknown}
    sig = inspect.signature(OneHotEncoder.__init__).parameters
    if "sparse_output" in sig:
        kwargs["sparse_output"] = False
    elif "sparse" in sig:
        kwargs["sparse"] = False
    return OneHotEncoder(**kwargs)


def fuzzy_match(name, columns):
    def norm(s): return re.sub(r"[^a-z0-9]", "", str(s).lower())
    n = norm(name)
    for col in columns:
        if norm(col) == n: return col
    for col in columns:
        if n in norm(col) or norm(col) in n: return col
    tokens = set(re.findall(r"[a-z0-9]+", name.lower()))
    best, best_sc = None, 0
    for col in columns:
        sc = len(tokens & set(re.findall(r"[a-z0-9]+", col.lower())))
        if sc > best_sc: best, best_sc = col, sc
    return best if best_sc > 0 else None


DATA_FILE = "file name"
df_raw = pd.read_excel(DATA_FILE)


ALL_TARGETS_NOMINAL = [
    "grain size", "roughness",
    "Carrier Lifetime", "Electron defect density",
    "Hole defect density", "Trap-Filled Limit Voltage electron",
    "Trap Density electron", "Trap-Filled Limit Voltage hole",
    "Trap Density  Hole", "Electron Mobility", "Hole Mobility", "Conductivity",
    "Photoluminescence Lifetime", "Absorption Edge",
]


EXTRA_NON_PREDICTOR_NAMES = ["Bandgap", "Urbach Energy"]

MIN_SAMPLES   = 20
METADATA_COLS = ["Ref_no", "Ref No", "Ref", "Year", "Structure", "SUBSTRATE", "Index"]

eligible_targets, excluded_targets, target_col_map = [], [], {}

for name in ALL_TARGETS_NOMINAL:
    col = fuzzy_match(name, df_raw.columns)
    if col is None: continue
    n = int(df_raw[col].notna().sum())
    target_col_map[name] = col
    if n >= MIN_SAMPLES:
        eligible_targets.append(col)
    else:
        excluded_targets.append(col)

all_target_cols = eligible_targets + excluded_targets

extra_excl_cols = []
for name in EXTRA_NON_PREDICTOR_NAMES:
    col = fuzzy_match(name, df_raw.columns)
    if col and col not in all_target_cols:
        extra_excl_cols.append(col)


exclude_from_preds = set(all_target_cols) | set(extra_excl_cols) | set(METADATA_COLS)
candidate_cols     = [c for c in df_raw.columns if c not in exclude_from_preds]

df_preds   = df_raw[candidate_cols].copy()
num_cols_g = df_preds.select_dtypes(include=["number"]).columns.tolist()
cat_cols_g = [c for c in df_preds.columns if c not in num_cols_g]

parts = [("num", Pipeline([
              ("imp", IterativeImputer(random_state=42, max_iter=10)),
              ("sc",  StandardScaler()),
          ]), num_cols_g)]
if cat_cols_g:
    parts.append(("cat", Pipeline([
        ("imp", SimpleImputer(strategy="most_frequent")),
        ("ohe", make_onehot()),
    ]), cat_cols_g))

global_pre   = ColumnTransformer(parts)
X_global     = global_pre.fit_transform(df_preds)

try:
    feat_names = [n.split("__", 1)[-1] for n in global_pre.get_feature_names_out()]
except Exception:
    feat_names = [f"f{i}" for i in range(X_global.shape[1])]

df_pred_proc = pd.DataFrame(X_global, columns=feat_names)
X_scaled     = X_global



kmeans        = KMeans(n_clusters=3, n_init=10, random_state=42)
kmeans_labels = kmeans.fit_predict(X_scaled)

DBSCAN_FINAL_EPS = 1.0
db_labels_dict   = {}
for eps_val in [0.3, 0.5, 1.0]:
    db_run = DBSCAN(eps=eps_val, min_samples=5).fit(X_scaled)
    db_labels_dict[eps_val] = db_run.labels_

dbscan_labels = db_labels_dict[DBSCAN_FINAL_EPS]


target_obs_df = df_raw[all_target_cols].copy()
corr_targets  = target_obs_df.corr(method="pearson")  # pairwise complete obs.

TOP_N        = 10
corr_rows    = []

for t_col in all_target_cols:
    obs   = df_raw[t_col].notna().values
    n_obs = obs.sum()
    if n_obs < 5:
        continue
    y_obs_t = df_raw.loc[obs, t_col].values
    X_obs   = df_pred_proc[obs]
    r       = X_obs.apply(lambda c: np.corrcoef(c.values, y_obs_t)[0, 1])
    top     = r.abs().sort_values(ascending=False).head(TOP_N).index
    for rank, feat in enumerate(top, 1):
        corr_rows.append({"Target"   : t_col,
                           "Rank"     : rank,
                           "Feature"  : feat,
                           "Pearson_r": round(float(r[feat]), 6)})


imp_causal = IterativeImputer(random_state=42, max_iter=10)
T_imputed  = pd.DataFrame(
    imp_causal.fit_transform(target_obs_df),
    columns=target_obs_df.columns,
)
T_scaled     = StandardScaler().fit_transform(T_imputed)
causal_edges = []

try:
    gl   = GraphicalLassoCV(cv=3, max_iter=500).fit(T_scaled)
    prec = gl.precision_.copy()
    np.fill_diagonal(prec, 0)

    nonzero   = np.abs(prec[np.abs(prec) > 1e-9])
    threshold = float(np.percentile(nonzero, 70)) if len(nonzero) > 0 else 1e-6
    adj       = (np.abs(prec) > threshold).astype(int)

    col_list = T_imputed.columns.tolist()
    corr_mat = corr_targets.values
    for i in range(adj.shape[0]):
        for j in range(i + 1, adj.shape[0]):
            if adj[i, j]:
                si   = np.sum(np.abs(corr_mat[i, :]))
                sj   = np.sum(np.abs(corr_mat[j, :]))
                edge = (col_list[i], col_list[j]) if si >= sj \
                    else (col_list[j], col_list[i])
                causal_edges.append(edge)

    
except Exception:
    pass

TARGET   = fuzzy_match("Trap Density electron", df_raw.columns)
obs_mask = df_raw[TARGET].notna().values
n_obs    = int(obs_mask.sum())

X_raw = df_preds[obs_mask].copy().reset_index(drop=True)
y_obs = df_raw.loc[obs_mask, TARGET].values

X_raw["KMeans_cluster"] = kmeans_labels[obs_mask].astype(float)
X_raw["DBSCAN_cluster"]  = dbscan_labels[obs_mask].astype(float)

num_cols_s = X_raw.select_dtypes(include=["number"]).columns.tolist()
cat_cols_s = [c for c in X_raw.columns if c not in num_cols_s]

sup_parts = [("num", Pipeline([
                  ("imp", IterativeImputer(random_state=42, max_iter=10)),
                  ("sc",  StandardScaler()),
              ]), num_cols_s)]
if cat_cols_s:
    sup_parts.append(("cat", Pipeline([
        ("imp", SimpleImputer(strategy="most_frequent")),
        ("ohe", make_onehot()),
    ]), cat_cols_s))

sup_pre = ColumnTransformer(sup_parts)
KF      = KFold(n_splits=5, shuffle=True, random_state=42)

X_train, X_test, y_train, y_test = train_test_split(
    X_raw, y_obs, test_size=0.20, random_state=42,
)

BENCHMARK_MODELS = {
    "Random Forest"          : RandomForestRegressor(random_state=42),
    "Hist Gradient Boosting" : HistGradientBoostingRegressor(random_state=42),
    "KNN"                    : KNeighborsRegressor(),
    "Elastic Net"            : ElasticNet(),
    "Decision Tree"          : DecisionTreeRegressor(random_state=42),
    "Bayesian Ridge"         : BayesianRidge(),
    "SVR linear"             : SVR(kernel="linear"),
    "MLP small"              : MLPRegressor(hidden_layer_sizes=(50,),
                                            max_iter=2000, random_state=42),
    "Ridge"                  : Ridge(),
    "Lasso"                  : Lasso(),
    "Linear Regression"      : LinearRegression(),
}

bench_rows = []
for mname, estimator in BENCHMARK_MODELS.items():
    pipe = Pipeline([("pre", sup_pre), ("model", estimator)])
    pipe.fit(X_train, y_train)
    tr = float(r2_score(y_train, pipe.predict(X_train)))
    te = float(r2_score(y_test,  pipe.predict(X_test)))
    cv = float(np.mean(cross_val_score(pipe, X_raw, y_obs, cv=KF, scoring="r2")))
    bench_rows.append({"Model"   : mname,
                        "Train R2": round(tr, 6),
                        "Test R2" : round(te, 6),
                        "CV R2"   : round(cv, 6)})

rf_gs_pipe = Pipeline([
    ("pre",   sup_pre),
    ("model", RandomForestRegressor(random_state=42, n_jobs=-1)),
])
PARAM_GRID = {
    "model__n_estimators"    : [100, 200, 500],
    "model__max_depth"       : [6, 12, None],
    "model__min_samples_leaf": [1, 3],
}
gs = GridSearchCV(rf_gs_pipe, PARAM_GRID, cv=KF,
                  scoring="r2", n_jobs=-1, refit=True)
gs.fit(X_train, y_train)
best_pipe = gs.best_estimator_

rkf = RepeatedKFold(n_splits=20, n_repeats=1000, random_state=42)
cross_val_score(
    Pipeline([
        ("pre",   sup_pre),
        ("model", RandomForestRegressor(
                      n_estimators     = gs.best_params_["model__n_estimators"],
                      max_depth        = gs.best_params_["model__max_depth"],
                      min_samples_leaf = gs.best_params_["model__min_samples_leaf"],
                      n_jobs           = 1,
                      random_state     = 42)),
    ]),
    X_raw, y_obs,
    cv      = rkf,
    scoring = "r2",
    n_jobs  = 1,
)


rf_fit    = best_pipe.named_steps["model"]
pre_fit   = best_pipe.named_steps["pre"]
X_te_proc = pre_fit.transform(X_test)
n_out     = X_te_proc.shape[1]

try:
    all_feat_names = [s.split("__", 1)[-1] for s in pre_fit.get_feature_names_out()]
except Exception:
    all_feat_names = [f"f{i}" for i in range(n_out)]
if len(all_feat_names) != n_out:
    all_feat_names = [f"f{i}" for i in range(n_out)]

X_te_df   = pd.DataFrame(X_te_proc, columns=all_feat_names)
shap_vals = shap.TreeExplainer(rf_fit).shap_values(X_te_df)

